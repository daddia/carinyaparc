# Sanity CMS Configuration
# Copy this file to .env.local and fill in your values.

# Sanity project ID (public, safe for browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (public, safe for browser)
# Use "production" for live content or "development" for testing
NEXT_PUBLIC_SANITY_DATASET=development

# Sanity API read token (server-side only, do NOT prefix with NEXT_PUBLIC_)
# Generate at: https://www.sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=
